generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Analysis {
  id           String   @id @default(cuid())
  sourceUrl    String
  propertyData String   // JSON stored as string
  postcode     String?
  createdAt    DateTime @default(now())

  @@index([sourceUrl])
}

model SavedProperty {
  id            String   @id // Property ID from the scraped data
  userId        String   @default("admin") // 'admin' or 'demo'
  url           String
  timestamp     DateTime @default(now())
  propertyData  String   // JSON: Property object
  schoolsData   String?  // JSON: AttendedSchoolsResult or null
  aiAnalysis    String?  // AI analysis text
  aiModel       String?  // AI model used
  ai2Analysis   String?  // Second AI analysis (optional)
  ai2Model      String?  // Second AI model used (optional)
  commuteTimes  String   // JSON array
  isStarred     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([timestamp])
  @@index([userId])
}

// Tracks admin-owned properties hidden from demo's view (soft-delete for demo)
model DemoHiddenProperty {
  propertyId String @id // The admin-owned property ID demo has "deleted"
  createdAt  DateTime @default(now())
}

// Tracks the start time of the 24-hour stratgroup session
model StratgroupSession {
  id        String   @id @default("stratgroup")
  startedAt DateTime @default(now())
}

// Server-side analysis job — tracks pipeline progress independently of browser session
model AnalysisJob {
  id            String   @id @default(cuid())
  userId        String   @default("admin")
  url           String
  propertyId    String?  // Set once scrape completes
  status        String   @default("queued") // queued | scraping | enriching | analyzing | complete | error
  error         String?

  // Results stored as JSON strings (populated as each step completes)
  propertyData     String?  // From analyze
  schoolsData      String?  // From schools
  marketData       String?  // From market-data
  plotSizeData      String?  // From plot-size
  transactionsData String?  // From transactions
  stationsData     String?  // From stations
  commuteData      String?  // From commute
  aiAnalysis       String?  // From ai-analysis
  aiModel          String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([status])
}
